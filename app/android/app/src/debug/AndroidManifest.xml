<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application>
        <!--
          Solo para los tests de aceptación (ver
          ../../../integration_test/*_acceptance_test.dart y el método
          `useTestSafDocument` en MainActivity.kt) — vive en el source set
          `debug`, así que el merge de manifests lo añade a builds de
          debug/profile pero NUNCA a un .apk/.aab de release real.
          `useTestSafDocument` mint una URI content:// de este proveedor a
          un archivo en la caché de la app y hace que el selector de
          guardar/abrir la devuelva sin abrir el selector real del sistema
          (imposible de automatizar bajo `flutter test -d emulator`) — así
          el resto del flujo (ContentResolver, truncado, lectura) se
          ejercita de verdad, sin depender de la UI de otra app
          (DocumentsUI).
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.lcp_builder.acceptancetest.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
